{
  "_README": "이 파일을 .pi/mcp.json 로 복사한 뒤 <...> 부분을 실제 값으로 채우세요. .pi/mcp.json 은 gitignore되어 커밋되지 않습니다. 자세한 절차는 docs/MCP_GUIDE.md 참고.",
  "mcpServers": {
    "gmail": {
      "url": "https://gmailmcp.googleapis.com/mcp/v1",
      "auth": "oauth",
      "oauth": {
        "clientId": "<여기에_OAuth_클라이언트_ID>.apps.googleusercontent.com",
        "clientSecret": "<여기에_OAuth_클라이언트_비밀_GOCSPX-...>",
        "redirectUri": "http://localhost:3118/callback",
        "scope": "https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.compose"
      }
    },
    "gmail-send": {
      "command": "node",
      "args": ["./mcp-servers/gmail-send/index.mjs"]
    }
  }
}

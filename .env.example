# ============================================================
#  이 프로젝트의 모든 키/비밀을 모아두는 단일 소스.
#  사용:  cp .env.example .env   → 아래 값 채우기 → node mcp-servers/setup.mjs
#  .env 는 gitignore됨(커밋 안 됨). setup.mjs가 이걸 읽어 .pi/mcp.json 을 생성한다.
# ============================================================

# === Gmail OAuth (Google Cloud → OAuth 클라이언트, 웹 애플리케이션) ===
# 발급 절차: docs/MCP_GUIDE.md §4. 리디렉션 URI 는 http://localhost:3118/callback
GMAIL_OAUTH_CLIENT_ID=<여기에_클라이언트_ID>.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=<여기에_클라이언트_비밀_GOCSPX-...>

# === 모델 프로바이더 (Pi 가 자동 인식) ===
# /login OAuth 를 쓰면 비워둬도 됨. OpenRouter 종량제로 갈 땐 키 입력.
OPENROUTER_API_KEY=
